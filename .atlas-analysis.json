  "keyFeatures": [
    "Decorator-based memoization for functions and getters",
    "Configurable cache with maxAge and maxSize options",
    "Cache statistics and monitoring",
    "Custom key generation and equality comparison",
    "Promise/async function support",
    "Debug mode with cache hit/miss logging",
    "Tree-shakable and lightweight"
  ],
  "publicApiSurface": [
    "@Ngememoize() - Decorator for memoizing methods and getters",
    "NgememoizeService - Service for cache management and statistics",
    "MemoizeOptions - Configuration options interface",
    "CacheMap - Type for cache storage",
    "CacheStats - Interface for cache statistics",
    "KeyGeneratorFunction - Type for custom key generators",
    "EqualityComparator - Type for custom equality functions"
  ]
